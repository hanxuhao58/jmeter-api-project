    "firstName": "${__P(REG_OPTIN_FIRST_NAME)}",
    "lastName": "${__P(REG_OPTIN_LAST_NAME)}",
    "email": "${__P(REG_OPTIN_USER_NAME)}",
    "password": "${__P(REG_OPTIN_PASSWORD)}",
    "optIn": true,
    "thirdPartyOptIn": true
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Local Header Override">
