        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="1.1 iOS Login with Correct Credentials">
          <stringProp name="TestPlan.comments">使用正确的用户名和密码登录。预期成功 (200)。</stringProp>
          <stringProp name="HTTPSampler.domain">${HOST_BFF}</stringProp>
          <stringProp name="HTTPSampler.protocol">${PROTOCOL}</stringProp>
          <stringProp name="HTTPSampler.path">/v1/authentication/login</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
    &quot;password&quot;: &quot;${CORRECT_PASSWORD}&quot;&#xd;
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Local Header Override" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="断言状态码 200 (OK)" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <JSONPathAssertion guiclass="JSONPathAssertionGui" testclass="JSONPathAssertion" testname="断言 userId 存在" enabled="true">
            <stringProp name="JSON_PATH">$.userId</stringProp>
            <stringProp name="EXPECTED_VALUE"></stringProp>
            <boolProp name="JSONVALIDATION">true</boolProp>
            <boolProp name="EXPECT_NULL">false</boolProp>
            <boolProp name="INVERT">false</boolProp>
            <boolProp name="ISREGEX">true</boolProp>
          </JSONPathAssertion>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract and Save Tokens to CSV" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper
import java.nio.file.Paths
import java.nio.file.Files

// 1. 获取项目根目录
// JMeter 默认会设置 "user.dir" 为 bin 目录，所以我们用这个属性来定位项目根目录
def projectRoot = System.getProperty("user.dir")
// 如果是从 /bin 目录启动，需要返回上一级目录
if (projectRoot.endsWith(File.separator + "bin")) {
    projectRoot = new File(projectRoot).getParent()
}

def dataDir = new File(projectRoot, "data")
if (!dataDir.exists()) {
    dataDir.mkdirs()
}

// 2. 解析 JSON 响应
def response = prev.getResponseDataAsString()
def slurper = new JsonSlurper()
def result = slurper.parseText(response)

// 3. 提取所需字段
def userId = result.userId
def userToken = result.userToken
def userAuthorization = result.authorization

// 4. 将提取的数据写入 auth_tokens.csv 文件
// 使用 Paths 来构建文件路径，确保跨平台兼容性
File tokenFile = new File(dataDir, "auth_tokens.csv")

// 写入 CSV，如果文件不存在则创建，如果存在则覆盖
// 添加表头
tokenFile.write("userId,userToken,userAuthorization\n")
// 追加提取的数据
tokenFile.append(userId + "," + userToken + "," + userAuthorization + "\n")

// 5. (可选) 将提取的值设置为 JMeter 属性，供后续脚本直接使用
props.put("extracted_userId", userId.toString())
props.put("extracted_userToken", userToken)
props.put("extracted_userAuthorization", userAuthorization)

log.info("Tokens extracted and saved to " + tokenFile.getAbsolutePath())
log.info("userId=" + userId + ", userToken=" + userToken + ", authorization=" + userAuthorization)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
